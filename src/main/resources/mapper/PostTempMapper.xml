<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.globalgates.mapper.PostTempMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into tbl_post_temp (member_id, post_temp_content)
        values (#{memberId}, #{postTempContent})
    </insert>

    <select id="selectById">
        select id, member_id, post_temp_content, created_datetime, updated_datetime
        from tbl_post_temp
        where id = #{id}
    </select>

    <select id="selectAllByMemberId">
        select id, member_id, post_temp_content, created_datetime, updated_datetime
        from tbl_post_temp
        where member_id = #{memberId}
        order by created_datetime desc
    </select>

    <delete id="delete">
        delete
        from tbl_post_temp
        where id = #{id}
    </delete>

    <delete id="deleteAllByMemberId">
        delete
        from tbl_post_temp
        where member_id = #{memberId}
    </delete>

</mapper>
